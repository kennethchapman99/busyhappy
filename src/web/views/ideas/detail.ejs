<% title = idea.title %>

<div class="p-8 max-w-3xl">

  <!-- Back -->
  <a href="/ideas" class="text-sm text-zinc-500 hover:text-zinc-700 mb-6 inline-flex items-center gap-1">
    ← Back to Idea Vault
  </a>

  <!-- Header -->
  <div class="flex items-start justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold"><%= idea.title %></h1>
      <div class="flex items-center gap-2 mt-2">
        <span class="<%= statusBadge(idea.status) %>"><%= idea.status %></span>
        <span class="text-sm text-zinc-400">Created <%= formatDate(idea.created_at) %></span>
        <% if (idea.source_type) { %><span class="text-xs text-zinc-400">· source: <%= idea.source_type %></span><% } %>
      </div>
    </div>
    <div class="flex gap-2 shrink-0">
      <a href="/ideas/<%= idea.id %>/edit" class="border border-zinc-200 text-sm px-3 py-1.5 rounded-lg hover:bg-zinc-50 transition">Edit</a>
      <% if (idea.status !== 'promoted') { %>
      <button onclick="promoteIdea('<%= idea.id %>')"
        class="bg-green-700 text-white text-sm px-4 py-1.5 rounded-lg hover:bg-green-600 transition font-medium">
        🚀 Promote to Song
      </button>
      <% } %>
    </div>
  </div>

  <!-- Promoted banner -->
  <% if (song) { %>
  <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 flex items-center justify-between">
    <div>
      <div class="text-sm font-medium text-green-800">Promoted to Song</div>
      <div class="text-sm text-green-700"><%= song.title || song.id %></div>
    </div>
    <a href="/songs/<%= song.id %>" class="text-sm text-green-700 font-medium hover:underline">View Song →</a>
  </div>
  <% } %>

  <!-- Core fields -->
  <div class="bg-white border border-zinc-200 rounded-xl divide-y divide-zinc-100">
    <% const row = (label, val) => val ? `<div class="px-5 py-4"><div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">${label}</div><div class="text-sm text-zinc-800">${val}</div></div>` : ''; %>

    <% if (idea.concept) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Concept</div>
      <div class="text-sm text-zinc-800"><%= idea.concept %></div>
    </div>
    <% } %>

    <% if (idea.hook) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Hook</div>
      <div class="text-sm text-zinc-800 italic">"<%= idea.hook %>"</div>
    </div>
    <% } %>

    <div class="px-5 py-4 grid grid-cols-3 gap-4">
      <% if (idea.target_age_range) { %>
      <div>
        <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Age Range</div>
        <div class="text-sm text-zinc-800"><%= idea.target_age_range %></div>
      </div>
      <% } %>
      <% if (idea.category) { %>
      <div>
        <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Category</div>
        <div class="text-sm text-zinc-800"><%= idea.category %></div>
      </div>
      <% } %>
      <% if (idea.mood) { %>
      <div>
        <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Mood</div>
        <div class="text-sm text-zinc-800"><%= idea.mood %></div>
      </div>
      <% } %>
    </div>

    <% if (idea.educational_angle) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Educational Angle</div>
      <div class="text-sm text-zinc-800"><%= idea.educational_angle %></div>
    </div>
    <% } %>

    <% if (idea.tags && idea.tags.length > 0) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-2">Tags</div>
      <div class="flex flex-wrap gap-2">
        <% for (const tag of idea.tags) { %>
          <span class="bg-blue-50 text-blue-600 text-xs px-2.5 py-1 rounded-full">#<%= tag %></span>
        <% } %>
      </div>
    </div>
    <% } %>

    <% if (idea.lyric_seed) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-2">Lyric Seed</div>
      <div class="bg-zinc-50 rounded-lg p-3 text-sm font-mono text-zinc-700 whitespace-pre-wrap"><%= idea.lyric_seed %></div>
    </div>
    <% } %>

    <% if (idea.thumbnail_seed) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Thumbnail Concept</div>
      <div class="text-sm text-zinc-700"><%= idea.thumbnail_seed %></div>
    </div>
    <% } %>

    <% if (idea.notes) { %>
    <div class="px-5 py-4">
      <div class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Notes</div>
      <div class="text-sm text-zinc-700 whitespace-pre-wrap"><%= idea.notes %></div>
    </div>
    <% } %>
  </div>

  <!-- Status actions -->
  <div class="mt-6 flex flex-wrap gap-2">
    <% const statuses = ['new','shortlisted','in_review','archived']; %>
    <% for (const s of statuses) { if (s !== idea.status) { %>
    <button onclick="setStatus('<%= idea.id %>', '<%= s %>')"
      class="border border-zinc-200 text-sm px-3 py-1.5 rounded-lg hover:bg-zinc-50 transition text-zinc-600">
      Mark <%= s %>
    </button>
    <% } } %>
  </div>

</div>

<script>
function promoteIdea(id) {
  fetch('/api/ideas/' + id + '/promote', { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      // Go straight to the pipeline terminal — generate right away
      if (d.generateUrl) window.location = d.generateUrl;
      else if (d.songId) window.location = '/songs/' + d.songId + '/generate';
    });
}
function setStatus(id, status) {
  fetch('/api/ideas/' + id + '/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  }).then(() => window.location.reload());
}
</script>
