<% title = 'Brand Bible' %>

<script>
window.brandEditor = function() {
  return {
    saving: false,
    saved: false,
    errorMsg: '',

    async save() {
      this.saving = true;
      this.saved = false;
      this.errorMsg = '';
      try {
        const form = document.getElementById('brand-form');
        const data = Object.fromEntries(new FormData(form).entries());
        const res = await fetch('/api/brand', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const d = await res.json();
        if (!d.ok) throw new Error(d.error || 'Save failed');
        this.saved = true;
        setTimeout(() => this.saved = false, 3000);
      } catch (err) {
        this.errorMsg = err.message;
      } finally {
        this.saving = false;
      }
    }
  };
};
</script>

<div class="p-8 max-w-4xl" x-data="brandEditor()">

  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold">🎨 Brand Bible</h1>
      <p class="text-sm text-zinc-500 mt-1">Edit the core brand rules that guide every song and idea generated.</p>
    </div>
    <div class="flex items-center gap-3">
      <span x-show="saved" class="text-sm text-emerald-600 font-medium">✓ Saved!</span>
      <span x-show="errorMsg" x-text="errorMsg" class="text-sm text-red-600"></span>
      <button @click="save()" :disabled="saving"
        class="bg-zinc-900 hover:bg-zinc-700 disabled:opacity-50 text-white font-semibold px-5 py-2 rounded-xl transition text-sm">
        <span x-show="!saving">💾 Save Changes</span>
        <span x-show="saving">Saving…</span>
      </button>
    </div>
  </div>

  <% if (!brand) { %>
  <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-red-700">
    Brand bible not found at <code class="font-mono text-sm">output/brand/brand-bible.md</code>. Run the pipeline once to generate it.
  </div>
  <% } else { %>
  <% const bd = brand.brand_data || {}; const ch = bd.character || {}; const vo = bd.voice || {}; const ru = bd.rules || {}; %>

  <form id="brand-form" @submit.prevent="save()">

    <!-- CHARACTER -->
    <section class="bg-white border border-zinc-200 rounded-xl mb-6 overflow-hidden">
      <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
        <h2 class="font-bold text-zinc-800">🤖 Character</h2>
        <p class="text-xs text-zinc-500 mt-0.5">The core identity of your mascot — name, personality, catchphrases.</p>
      </div>
      <div class="px-6 py-5 space-y-5">

        <div class="grid grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Character Name</label>
            <input type="text" name="character_name" value="<%= ch.name || '' %>"
              class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-900">
            <p class="text-xs text-zinc-400 mt-1">This name will appear in song suggestions and brand reviews.</p>
          </div>
        </div>

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Character Backstory</label>
          <textarea name="character_backstory" rows="3"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= ch.backstory || '' %></textarea>
        </div>

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Personality Traits <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
          <textarea name="personality_traits" rows="6"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= (ch.personality_traits || []).join('\n') %></textarea>
        </div>

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Catchphrases <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
          <textarea name="catchphrases" rows="5"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= (ch.catchphrases || []).join('\n') %></textarea>
        </div>

      </div>
    </section>

    <!-- VOICE -->
    <section class="bg-white border border-zinc-200 rounded-xl mb-6 overflow-hidden">
      <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
        <h2 class="font-bold text-zinc-800">🗣️ Voice & Tone</h2>
        <p class="text-xs text-zinc-500 mt-0.5">How the brand sounds — guides every lyric and idea generated.</p>
      </div>
      <div class="px-6 py-5 space-y-5">

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Tone</label>
          <textarea name="voice_tone" rows="2"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= vo.tone || '' %></textarea>
        </div>

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">
            Song Formula
            <span class="text-zinc-400 font-normal normal-case ml-1">— structure template for every song</span>
          </label>
          <textarea name="voice_formula" rows="4"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= vo.formula || '' %></textarea>
          <p class="text-xs text-zinc-400 mt-1">Tip: if the character name is appearing in every song, update this formula to say "character name used only when natural — not required in every song".</p>
        </div>

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Recurring Themes <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
          <textarea name="recurring_themes" rows="6"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= (vo.recurring_themes || []).join('\n') %></textarea>
        </div>

      </div>
    </section>

    <!-- RULES -->
    <section class="bg-white border border-zinc-200 rounded-xl mb-6 overflow-hidden">
      <div class="px-6 py-4 bg-zinc-50 border-b border-zinc-100">
        <h2 class="font-bold text-zinc-800">📋 Rules</h2>
        <p class="text-xs text-zinc-500 mt-0.5">Always/never rules and topic guardrails used during brand review.</p>
      </div>
      <div class="px-6 py-5 space-y-5">

        <div>
          <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Age Guardrails</label>
          <textarea name="age_guardrails" rows="3"
            class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-zinc-900 resize-y"><%= ru.age_guardrails || '' %></textarea>
        </div>

        <div class="grid grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-emerald-700 uppercase tracking-wide mb-1.5">Always Do <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
            <textarea name="rules_always" rows="10"
              class="w-full border border-emerald-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-emerald-400 resize-y"><%= (ru.always || []).join('\n') %></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-red-700 uppercase tracking-wide mb-1.5">Never Do <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
            <textarea name="rules_never" rows="10"
              class="w-full border border-red-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-red-300 resize-y"><%= (ru.never || []).join('\n') %></textarea>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-5">
          <div>
            <label class="block text-xs font-semibold text-blue-700 uppercase tracking-wide mb-1.5">On-Brand Topics <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
            <textarea name="on_brand_topics" rows="8"
              class="w-full border border-blue-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-300 resize-y"><%= (ru.on_brand_topics || []).join('\n') %></textarea>
          </div>
          <div>
            <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wide mb-1.5">Off-Brand Topics <span class="text-zinc-400 font-normal normal-case">(one per line)</span></label>
            <textarea name="off_brand_topics" rows="8"
              class="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-zinc-400 resize-y"><%= (ru.off_brand_topics || []).join('\n') %></textarea>
          </div>
        </div>

      </div>
    </section>

    <!-- Sticky save bar at bottom -->
    <div class="sticky bottom-0 bg-white border-t border-zinc-200 -mx-8 px-8 py-4 flex items-center justify-between shadow-lg">
      <p class="text-xs text-zinc-400">Changes take effect on the next song generation or idea run.</p>
      <div class="flex items-center gap-3">
        <span x-show="saved" class="text-sm text-emerald-600 font-medium">✓ Saved!</span>
        <span x-show="errorMsg" x-text="errorMsg" class="text-sm text-red-600"></span>
        <button type="submit" :disabled="saving"
          class="bg-zinc-900 hover:bg-zinc-700 disabled:opacity-50 text-white font-semibold px-6 py-2.5 rounded-xl transition text-sm">
          <span x-show="!saving">💾 Save Changes</span>
          <span x-show="saving">Saving…</span>
        </button>
      </div>
    </div>

  </form>
  <% } %>

</div>
